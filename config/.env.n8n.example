# ── n8n 环境变量（用于 docker-compose） ──

# Hermes webhook 地址（接收告警转发）
# 工作流中默认值: http://localhost:8644/webhooks/alert-receiver
# 复制为实际 .env 后再改成你的 Hermes 地址；勿把真实内网 IP 提交进仓库示例文件
HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/alert-receiver

# HMAC 签名密钥（与 Hermes gateway 的 secret 一致）
WEBHOOK_SECRET=your-hmac-secret-here

# 监控的容器名（Code 节点通过 Docker API 采集日志）
# 工作流中默认值: your-container（务必改成真实容器名）
MONITOR_CONTAINER=your-container

# 飞书机器人配置（可选）
FEISHU_BOT_TOKEN=
FEISHU_GROUP_ID=
