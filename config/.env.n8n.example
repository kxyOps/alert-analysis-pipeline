# ── n8n 环境变量（用于 docker-compose） ──

# Hermes webhook 地址（接收告警转发）
# 工作流中默认值: http://localhost:8644/webhooks/alert-receiver
HERMES_WEBHOOK_URL=http://your-hermes-server:8644/webhooks/alert-receiver

# HMAC 签名密钥（与 Hermes gateway 的 secret 一致）
WEBHOOK_SECRET=your-hmac-secret-here

# 监控的容器名（Code 节点通过 Docker API 采集日志）
# 工作流中默认值: doris-standalone
MONITOR_CONTAINER=your-app-container

# 飞书机器人配置（可选）
FEISHU_BOT_TOKEN=
FEISHU_GROUP_ID=
