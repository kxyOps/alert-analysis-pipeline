# ── deploy 环境变量 ──
# 复制本文件为 deploy/.env 后按需修改。
# 勿提交 deploy/.env；勿把真实内网 IP、密钥写进任何会 push 的文件。

# Grafana 管理员密码（登录 admin / 此处密码；勿在生产使用默认值）
GF_SECURITY_ADMIN_PASSWORD=changeme

# Hermes webhook（本机开发可用 127.0.0.1；远程网关请在本机 .env 里写实际主机名/IP，不要回填进 .env.example）
HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/alert-receiver

# HMAC 签名密钥（与 Hermes / n8n 一致）
WEBHOOK_SECRET=your-hmac-secret-here

# 监控的容器名（n8n 通过 Docker API 采日志；改成你实际运行的容器名）
MONITOR_CONTAINER=your-container

# KB CLI / KB Web 展示用时间戳（可选；IANA 名称优先于整数偏移）
# KB_TIMEZONE=Asia/Shanghai
# KB_TZ_OFFSET=8
