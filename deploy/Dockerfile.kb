FROM python:3.11-alpine

# ZoneInfo 需要系统时区数据库（KB_TIMEZONE / TZ 用 IANA 名称时）
RUN apk add --no-cache tzdata

WORKDIR /app

# 仅 stdlib；kb_tz 为默认时区解析（见 README / KB_TIMEZONE）
COPY src/kb-server.py src/kb_tz.py /app/

EXPOSE 8888

ENV KB_DATA_DIR=/data
ENV KB_PORT=8888

VOLUME ["/data"]

CMD ["python3", "/app/kb-server.py"]
